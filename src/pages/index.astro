---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tracks } from '../data/curriculum';
---

<BaseLayout title="formalStatistics">
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16 sm:py-24 text-center">
    <h1
      class="text-4xl sm:text-5xl font-bold mb-4"
      style="font-family: var(--font-serif); color: var(--color-text-heading);"
    >
      formal<span style="color: var(--color-primary);">Statistics</span>
    </h1>
    <p class="text-xl mb-2" style="color: var(--color-text-muted);">
      The probability and statistics foundations behind modern machine learning.
    </p>
    <p class="text-base mb-8 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      Deep-dive explainers combining rigorous mathematics, interactive visualizations, and working code.
      The bridge between
      <a href="https://formalcalculus.com" class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">formalCalculus</a>
      and
      <a href="https://formalml.com" class="text-[var(--color-primary)] hover:underline" target="_blank" rel="noopener">formalML</a>.
    </p>
    <div class="flex justify-center gap-4">
      <a
        href="/paths"
        class="px-6 py-3 rounded-lg text-white font-semibold transition-colors"
        style="background: var(--color-primary);"
      >
        View Curriculum
      </a>
      <a
        href="https://github.com/jonx0037/formalStatistics"
        target="_blank"
        rel="noopener"
        class="px-6 py-3 rounded-lg font-semibold border transition-colors"
        style="border-color: var(--color-border); color: var(--color-text);"
      >
        GitHub
      </a>
    </div>
  </section>

  <!-- Learning path -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-12">
    <div
      class="flex items-center justify-center gap-3 text-sm font-medium py-3 px-4 rounded-lg"
      style="background: var(--color-surface-alt); border: 1px solid var(--color-border); color: var(--color-text-muted);"
    >
      <a href="https://formalcalculus.com" class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">
        formalCalculus
      </a>
      <span>&rarr;</span>
      <span style="color: var(--color-primary); font-weight: 700;">formalStatistics</span>
      <span>&rarr;</span>
      <a href="https://formalml.com" class="text-[var(--color-primary)] hover:underline" target="_blank" rel="noopener">
        formalML
      </a>
    </div>
  </section>

  <!-- Tracks overview -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
    <h2
      class="text-2xl font-bold mb-8 text-center"
      style="font-family: var(--font-serif); color: var(--color-text-heading);"
    >
      8 Tracks &middot; 32 Topics
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {tracks.map((track) => (
        <div
          class="rounded-lg border p-4"
          style="background: var(--color-surface-alt); border-color: var(--color-border);"
        >
          <div class="text-xs font-semibold mb-1" style="color: var(--color-primary);">
            Track {track.number}
          </div>
          <h3 class="font-semibold mb-1" style="color: var(--color-text-heading);">
            {track.title}
          </h3>
          <p class="text-sm mb-2" style="color: var(--color-text-muted);">
            {track.description}
          </p>
          <div class="text-xs" style="color: var(--color-text-muted);">
            {track.topicCount} topics
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
