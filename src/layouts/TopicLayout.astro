---
import BaseLayout from './BaseLayout.astro';
import ExternalLink from '../components/ui/ExternalLink.astro';
import graphData from '../data/curriculum-graph.json';

interface Props {
  title: string;
  subtitle: string;
  difficulty: 'foundational' | 'intermediate' | 'advanced';
  domain: string;
  estimatedReadTime?: number;
  datePublished?: Date;
  abstract?: string;
  formalcalculusPrereqs?: { topic: string; site: string; relationship: string }[];
  formalmlConnections?: { topic: string; site: string; relationship: string }[];
  connections?: { topic: string; relationship: string }[];
}

const {
  title,
  subtitle,
  difficulty,
  estimatedReadTime,
  datePublished,
  formalcalculusPrereqs = [],
  formalmlConnections = [],
  connections = [],
} = Astro.props;

const difficultyColors = {
  foundational: 'bg-green-100 text-green-800 border-green-300',
  intermediate: 'bg-blue-100 text-blue-800 border-blue-300',
  advanced: 'bg-purple-100 text-purple-800 border-purple-300',
};

const formattedDate = datePublished
  ? datePublished.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// Index by both node.id and URL slug so author-side slugs in frontmatter
// resolve regardless of which form they use (curriculum-graph.json uses short
// ids for some domains but full URL slugs for others).
const topicMeta = new Map<string, { label: string; url: string; status: 'published' | 'planned' }>();
for (const node of graphData.nodes) {
  const meta = {
    label: node.label,
    url: node.url,
    status: node.status as 'published' | 'planned',
  };
  topicMeta.set(node.id, meta);
  const urlSlug = node.url.replace(/^\/topics\//, '').replace(/\/$/, '');
  if (urlSlug !== node.id) topicMeta.set(urlSlug, meta);
}
---

<BaseLayout title={title} description={subtitle}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class={`px-2 py-0.5 rounded-full text-xs font-semibold border ${difficultyColors[difficulty]}`}>
          {difficulty}
        </span>
        {estimatedReadTime && (
          <span class="text-xs" style="color: var(--color-text-muted);">
            {estimatedReadTime} min read
          </span>
        )}
        {formattedDate && (
          <span class="text-xs" style="color: var(--color-text-muted);">
            &middot; {formattedDate}
          </span>
        )}
      </div>

      <h1
        class="text-3xl sm:text-4xl font-bold mb-3"
        style="font-family: var(--font-serif); color: var(--color-text-heading);"
      >
        {title}
      </h1>

      <p class="text-lg" style="color: var(--color-text-muted);">
        {subtitle}
      </p>

      <!-- Cross-site links -->
      {(formalcalculusPrereqs.length > 0 || formalmlConnections.length > 0) && (
        <div class="flex flex-wrap gap-2 mt-4">
          {formalcalculusPrereqs.map((prereq) => (
            <ExternalLink
              href={`https://formalcalculus.com/topics/${prereq.topic}`}
              site="formalcalculus"
              topic={prereq.topic.replace(/-/g, ' ')}
            />
          ))}
          {formalmlConnections.map((conn) => (
            <ExternalLink
              href={`https://formalml.com/topics/${conn.topic}`}
              site="formalml"
              topic={conn.topic.replace(/-/g, ' ')}
            />
          ))}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="topic-content">
      <slot />
    </div>

    <!-- Connections footer -->
    {connections.length > 0 && (
      <footer class="mt-16 pt-8 border-t" style="border-color: var(--color-border);">
        <h2
          class="text-lg font-bold mb-4"
          style="font-family: var(--font-serif); color: var(--color-text-heading);"
        >
          Where This Leads
        </h2>
        <div class="grid gap-3">
          {connections.map((conn) => {
            const meta = topicMeta.get(conn.topic);
            const label = meta?.label ?? conn.topic.replace(/-/g, ' ');
            const url = meta?.url ?? `/topics/${conn.topic}`;
            const isPlanned = meta?.status === 'planned';
            return (
              <div
                class="p-4 rounded-lg border"
                style="background: var(--color-surface-alt); border-color: var(--color-border);"
              >
                {isPlanned ? (
                  <span class="font-semibold" style="color: var(--color-text-heading);">
                    {label}
                  </span>
                ) : (
                  <a
                    href={url}
                    class="font-semibold hover:underline"
                    style="color: var(--color-primary);"
                  >
                    {label}
                  </a>
                )}
                {isPlanned && (
                  <span class="text-xs ml-2 px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 border border-gray-200">
                    coming soon
                  </span>
                )}
                <p class="text-sm mt-1" style="color: var(--color-text-muted);">
                  {conn.relationship}
                </p>
              </div>
            );
          })}
        </div>
      </footer>
    )}
  </article>
</BaseLayout>
